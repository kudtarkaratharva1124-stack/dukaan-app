# ---- Database ----
DB_USER=dukaanpro
DB_PASSWORD=change_me
DB_NAME=dukaanpro
DB_PORT=5432
DATABASE_URL=postgres://dukaanpro:change_me@localhost:5432/dukaanpro

# ---- API ----
API_PORT=4000
NODE_ENV=development
JWT_SECRET=4853e648a86ff60d61d3605523a02f0f35e0543bb4b37490f0e1e132048bea2e
JWT_REFRESH_SECRET=20ac6b28390484a84c5d5066848bdc01d599b883a3414198404037d14ad692c4
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
# Comma-free, single origin your frontend is served from in production, e.g.
# https://shop.example.com — defaults to "*" (any origin) if left blank, which is
# fine for local dev but should be locked down before going live.
CORS_ORIGIN=*

# ---- Frontend ----
# NOTE: Vite bakes VITE_* vars into the JS bundle at BUILD time, not container start
# time. If you change this after already running `docker compose build`, you must
# rebuild the frontend image (`docker compose build frontend`) for it to take effect —
# restarting the container alone will not pick up the new value.
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:4000/api

# ---- Payments (Razorpay) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- AI ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- Barcode lookup (scanner "not in inventory" online fallback) ----
# Uses Open Food Facts (free, no key) by default. Set to "false" to disable
# the online fallback entirely and only ever check local inventory + the
# shared barcode_catalog cache.
BARCODE_LOOKUP_ENABLED=true
BARCODE_LOOKUP_TIMEOUT_MS=5000

# ---- WhatsApp / SMS ----
FAST2SMS_API_KEY=
WHATSAPP_API_KEY=

# ---- Storage ----
UPLOAD_DIR=./src/uploads
MAX_UPLOAD_SIZE_MB=5

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
